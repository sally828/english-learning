      "notes": [
        {
          "title": "时间状语从句中不用将来时",
          "content": "在when, after, before等引导的时间状语从句中，用一般现在时表示将来。",
          "examples": [
            "✓ when I go to the company",
            "✓ after my boss comes back",
            "✗ when I will go",
            "✗ after my boss will come back"
          ]
        },
        {
          "title": "\"be responsible for\" 固定搭配",
          "content": "表示\"对...负责\"时，必须使用be动词。",
          "examples": [
            "✓ I will be responsible for the problem",
            "✓ I will be held responsible",
            "✗ I will responsible"
          ]
        },
        {
          "title": "\"adjust to\" 需要介词",
          "content": "adjust表示\"适应\"时，后面必须跟介词to。",
          "examples": [
            "✓ adjust to the company",
            "✓ adjust to the new environment",
            "✗ adjust with the company"
          ]
        },
        {
          "title": "动词搭配",
          "content": "不同场景使用不同的动词搭配。",
          "examples": [
            "join a company ✓",
            "attend a class ✓ (不是 join a class)",
            "receive requests ✓ (不是 get demands)",
            "tell someone ✓ (不是 say to someone)"
          ]
        }
      ],
