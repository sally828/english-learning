            {
              "cn": "值得注意的是",
              "en": "it's worth noting that",
              "ipa": "ɪts wɜːrθ ˈnoʊtɪŋ ðæt"
            },
            {
              "cn": "总体而言",
              "en": "overall / on the whole",
              "ipa": "ˌoʊvərˈɔːl"
            },
            {
              "cn": "换个角度看",
              "en": "to put this in perspective",
              "ipa": "tuː pʊt ðɪs ɪn pəˈspektɪv"
            },
            {
              "cn": "打断一下",
              "en": "sorry to interrupt",
              "ipa": "ˈsɒri tuː ˌɪntəˈrʌpt"
            },
            {
              "cn": "请允许我确认一下",
