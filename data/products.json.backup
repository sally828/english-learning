        {
          "id": "fe3",
          "icon": "📝",
          "image": "images/img1.png",
          "nameEn": "Grammar: Present Perfect — Full Pattern Library",
          "nameCn": "语法：现在完成时完整句型库",
          "tags": [
            "语法重点",
            "逐字稿错误",
            "100句型"
          ],
          "description": "Complete Present Perfect pattern library, organized by use case. Includes PP (have/has + V3) and PPC (have been + V-ing), with CFO/medical device workplace examples throughout.",
          "terms": [
            {
              "cn": "我最近状态不错",
              "en": "I've been good",
              "ipa": "aɪv biːn ɡʊd"
            },
            {
              "cn": "我最近很忙",
              "en": "I've been really busy",
              "ipa": "aɪv biːn ˈrɪəli ˈbɪzi"
            },
            {
              "cn": "我最近很好，谢谢",
              "en": "I've been well, thank you",
              "ipa": "aɪv biːn wel"
            },
            {
              "cn": "这周还不错",
              "en": "it's been a good week",
              "ipa": "ɪts biːn ə ɡʊd wiːk"
            },
            {
              "cn": "这几天挺充实的",
              "en": "it's been a productive few days",
              "ipa": "ɪts biːn ə prəˈdʌktɪv fjuː deɪz"
